{
  "name": "madrasty",
  "version": "0.0.0",
  "private": true,
  "description": "Madrasty — Egyptian EdTech SaaS platform (monorepo)",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace @madrasty/server",
    "dev:client": "npm run dev --workspace @madrasty/client",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.19.12": true,
    "esbuild@0.28.1": true
  }
}
