# ---------------------------------------------------------------------------
# Madrasty — environment variables (template)
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#   cp .env.example .env
# Leave a key blank until the matching integration is actually built
# (docs 04/05/06 for payments, doc 01 §5 for infra choices).
# ---------------------------------------------------------------------------

# --- Core / app ------------------------------------------------------------
NODE_ENV=development
PORT=4000
# Public URL of the API and the client (used for CORS, webhooks, redirects).
API_BASE_URL=http://localhost:4000
CLIENT_BASE_URL=http://localhost:5173
# Vite only exposes VITE_-prefixed vars to client-side code — keep these in
# sync with DEFAULT_LOCALE / SUPPORTED_LOCALES above.
# The client calls the API via a relative path so it stays same-origin with the
# dev server (Vite proxies /api → API_BASE_URL) — this keeps the httpOnly refresh
# cookie flowing. In production point this at the API origin (or keep /api behind
# a reverse proxy that fronts both the app and the API).
VITE_API_BASE_URL=/api
VITE_DEFAULT_LOCALE=ar
VITE_SUPPORTED_LOCALES=ar,en

# --- Database (PostgreSQL, doc 01 §5 / doc 14) -----------------------------
# These POSTGRES_* values feed both docker-compose and DATABASE_URL below —
# keep them in sync.
POSTGRES_USER=madrasty
POSTGRES_PASSWORD=madrasty_dev_password
POSTGRES_DB=madrasty_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://madrasty:madrasty_dev_password@localhost:5432/madrasty_dev

# --- Cache / queue (Redis, used for sessions, rate-limit, BullMQ jobs) ------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Auth (doc 01 §5, doc 11) ----------------------------------------------
# Generate long random strings, e.g. `openssl rand -hex 32`.
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Payment gateways (doc 04) ---------------------------------------------
# Paymob is the primary gateway (proxies Fawry / Vodafone Cash / cards).
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID=
# Direct integrations (add as needed, doc 04 §2).
FAWRY_API_KEY=
FAWRY_MERCHANT_CODE=
VODAFONE_CASH_API_KEY=
INSTAPAY_API_KEY=
# International cards (phase 2).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- AI services (doc 01 §3 — LLM API, not self-hosted) --------------------
# Prompt-based AI tutor / quiz generation / homework grading.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Object storage (video/files — Cloudflare R2 or AWS S3, doc 01 §5) -----
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Video hosting/streaming (Bunny.net Stream or Mux, doc 01 §5) ----------
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# --- Realtime / live classes (Agora.io or 100ms + Socket.io, doc 01 §5) ----
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# --- Notifications (email / SMS / WhatsApp, doc 01 §3) ---------------------
# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@madrasty.app
# SMS / OTP (doc 11)
SMS_PROVIDER_API_KEY=
SMS_SENDER_ID=
# WhatsApp
WHATSAPP_API_KEY=

# --- i18n (doc 07) ---------------------------------------------------------
DEFAULT_LOCALE=ar
SUPPORTED_LOCALES=ar,en
